# MAPtimize environment configuration
# Copy to .env and fill in the values. NEVER commit the real .env.
# Secrets (passwords, JWT secret, API keys/tokens) must be strong, unique values.

# ── Database (PostgreSQL + pgvector) ────────────────────────────────────────
POSTGRES_USER=maptimize
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=maptimize

# ── Redis (password-protected) ──────────────────────────────────────────────
# Required: the backend and redis container both authenticate with this.
REDIS_PASSWORD=change-me-strong-redis-password
# Must include the password; keep in sync with REDIS_PASSWORD above.
REDIS_URL=redis://:change-me-strong-redis-password@maptimize-redis:6379/0

# ── Auth / JWT ──────────────────────────────────────────────────────────────
# Generate a strong random secret, e.g. `openssl rand -hex 32`.
JWT_SECRET=change-me-generate-a-32-byte-random-hex
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Default admin (seeded on first startup) ─────────────────────────────────
DEFAULT_ADMIN_EMAIL=admin@utia.cas.cz
# Required: no insecure default is provided anymore.
DEFAULT_ADMIN_PASSWORD=change-me-strong-admin-password

# ── AI / ML services ────────────────────────────────────────────────────────
# Gemini API key for the chat agent (leave empty to disable chat).
GEMINI_API_KEY=
# HuggingFace token for downloading gated model weights (Qwen VL, etc.).
HF_TOKEN=

# ── GPU / model manager ─────────────────────────────────────────────────────
CUDA_VISIBLE_DEVICES=0
GPU_MEMORY_FRACTION=0.66
GPU_MODEL_IDLE_TIMEOUT_SECONDS=300
GPU_MODEL_CLEANUP_INTERVAL_SECONDS=60
ML_MEMORY_LIMIT_GB=16
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# ── YOLO cell detection ─────────────────────────────────────────────────────
YOLO_MODEL_PATH=/app/weights/best.pt
YOLO_CONFIDENCE_THRESHOLD=0.25
YOLO_IOU_THRESHOLD=0.45

# ── App / URLs ──────────────────────────────────────────────────────────────
DEBUG=false
ENVIRONMENT=production
# Public URL the browser uses to reach the API.
NEXT_PUBLIC_API_URL=https://maptimize.utia.cas.cz
API_BASE_URL=https://maptimize.utia.cas.cz
FRONTEND_URL=https://maptimize.utia.cas.cz
