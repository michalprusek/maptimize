# Copy to .env and fill in. These are read from the process environment; when
# launched by Claude Code / Claude Desktop, set them in the client's MCP config
# `env` block instead (see README) so nothing secret lands in the repo.

# Where the maptalk backend lives. localhost:7001 = prod backend on the UTIA box;
# use https://maptimize.utia.cas.cz to reach it from a laptop.
MAPTALK_BASE_URL=http://localhost:7001

# The maptalk user to act as. All document ACL applies as this user.
MAPTALK_EMAIL=you@example.com
MAPTALK_PASSWORD=change-me

# Alternative to email+password: a pre-issued JWT (24h expiry, NOT auto-refreshed).
# MAPTALK_TOKEN=eyJhbGciOi...

# Optional.
MAPTALK_VERIFY_TLS=true
MAPTALK_TIMEOUT=60
# Point at an external editable copy of the tool registry (defaults to the
# packaged maptalk_mcp/tools.yaml):
# MAPTALK_TOOLS_FILE=/home/cvat/maptimize/mcp-server/maptalk_mcp/tools.yaml
